# AI Employee Vault — Gold Tier Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# ── Core (required) ───────────────────────────────────────────────────────────

# Neon Postgres connection string (required for DB persistence + /health green)
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# OpenAI API Key (required for AI summaries)
OPENAI_API_KEY=sk-your-key-here

# Instagram / Meta access token (required — set to any non-empty string for dev)
INSTAGRAM_ACCESS_TOKEN=your-instagram-token-here

# ── FastAPI server ────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins.  Use * for dev/HF Spaces.
ALLOWED_ORIGINS=*

# ── Agent tuning ─────────────────────────────────────────────────────────────

# OpenAI model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Max characters to send per task (default: 6000)
MAX_TASK_CHARS=6000

# Ralph Wiggum Loop settings
MAX_RETRIES=3
MAX_LOOPS=50
LOOP_DELAY=1.0

# ── MCP dry-run flag ─────────────────────────────────────────────────────────
# true  → all external API calls are simulated (safe default)
# false → real API calls made (requires valid credentials below)
MCP_DRY_RUN=true

# ── X (Twitter) API v2 ───────────────────────────────────────────────────────
# Required only when MCP_DRY_RUN=false.
# Generate at: https://developer.x.com/en/portal/dashboard
# Requires tweet.write scope (OAuth 2.0 user context).
X_BEARER_TOKEN=
# X_TIMEOUT_S=30   # optional, default 30 seconds

# ── Meta (Facebook / Instagram) Graph API v18 ────────────────────────────────
# Required only when MCP_DRY_RUN=false.
# Generate a Page-level access token at: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=
# META_TIMEOUT_S=30   # optional, default 30 seconds

# ── Odoo 19 Community JSON-RPC Integration ────────────────────────────────────
# Required only when MCP_DRY_RUN=false. Requires a local Odoo 19 instance.
ODOO_URL=http://localhost:8069
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=
# ODOO_TIMEOUT_S=30   # optional, default 30 seconds
